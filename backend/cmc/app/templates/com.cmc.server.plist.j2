<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cmc.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>${python_path_dir}/uvicorn</string>
        <string>cmc.app.factory:create_app</string>
        <string>--factory</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8765</string>
    </array>

    <key>WorkingDirectory</key>
    <string>${repo_root}</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <key>CMC_ENV</key>
        <string>install</string>
        <key>PATH</key>
        <string>${python_path_dir}:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>${repo_root}/.tmp/mission-control-queue/dispatcher-logs/server.out</string>

    <key>StandardErrorPath</key>
    <string>${repo_root}/.tmp/mission-control-queue/dispatcher-logs/server.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
