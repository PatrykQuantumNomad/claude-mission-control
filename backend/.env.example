# Claude Mission Control — example configuration
# Copy to .env and edit as needed; ALL values have sensible defaults so .env is optional.
# Paths below (DB_PATH, STATIC_DIR, ALEMBIC_INI_PATH) are interpreted RELATIVE TO THE REPO ROOT,
# not relative to the current working directory. This is enforced by Settings (cmc/config/settings.py).

# Server
HOST=127.0.0.1                    # Localhost only — never bind to 0.0.0.0 (LAN exposure)
PORT=8765

# Database
DB_PATH=data/cmc.db               # Resolved relative to repo root. Local FS only — WAL does NOT work on NFS / iCloud.
DB_ECHO=false                     # Set to true to log every SQL statement (noisy)

# Logging
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING / ERROR

# Frontend
STATIC_DIR=frontend/dist          # Resolved relative to repo root. Where Vite outputs the built SPA.

# Migrations
ALEMBIC_INI_PATH=backend/alembic.ini   # Resolved relative to repo root.
