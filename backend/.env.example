# Claude Mission Control — example configuration
# Copy to .env and edit as needed; ALL values have sensible defaults so .env is optional.
# Paths below (DB_PATH, STATIC_DIR, ALEMBIC_INI_PATH) are interpreted RELATIVE TO THE REPO ROOT,
# not relative to the current working directory. This is enforced by Settings (cmc/config/settings.py).

# Server
HOST=127.0.0.1                    # Localhost only — never bind to 0.0.0.0 (LAN exposure)
PORT=8765

# Database
DB_PATH=data/cmc.db               # Resolved relative to repo root. Local FS only — WAL does NOT work on NFS / iCloud.
DB_ECHO=false                     # Set to true to log every SQL statement (noisy)

# Logging
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING / ERROR
# LOG_FORMAT=text                 # text or json

# --- Production chassis hardening ---
# Defaults are local-first and safe to leave unset.
# DOCS_ENABLED=true
# OPENAPI_ENABLED=true
# REDOC_ENABLED=false
# HEALTH_CHECK_PATH=/healthcheck
# READINESS_CHECK_PATH=/ready
# READINESS_INCLUDE_DETAILS=false
# TRUSTED_HOSTS=["127.0.0.1","localhost","testserver","*.local"]
# CORS_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
# REQUEST_TIMEOUT_S=30
# MAX_REQUEST_BODY_BYTES=10000000
# SECURITY_HEADERS_ENABLED=true
# SECURITY_HSTS_ENABLED=false

# Optional JWT resource-server mode. Disabled by default.
# AUTH_ENABLED=false
# AUTH_JWT_SECRET=change-me-at-least-32-chars
# AUTH_JWT_AUDIENCE=
# AUTH_JWT_ISSUER=
# AUTH_JWKS_URL=

# Optional observability.
# METRICS_ENABLED=false
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional fixed-window rate limiting. Use Redis for multi-process deployments.
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_REQUESTS=120
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_STORAGE_URL=

# Frontend
STATIC_DIR=frontend/dist          # Resolved relative to repo root. Where Vite outputs the built SPA.

# Migrations
ALEMBIC_INI_PATH=backend/alembic.ini   # Resolved relative to repo root.

# --- Data Ingestion ---

# Directory holding Claude Code session JSONL files.
# Default: ~/.claude/projects (the standard Claude Code transcript location on macOS).
# Override only if you've moved Claude Code's data dir. Tests override this to a tmp dir.
# JSONL_ROOT=~/.claude/projects

# Threshold (minutes) for inferring a session has ended.
# When a JSONL file's mtime is older than this and the scraper has read to EOF,
# `sessions.ended_at` is set to the timestamp of the last message.
# Default 5 matches SESS-03 ("live sessions" = active in last 5 min).
# SESSION_IDLE_MINUTES=5

# Maximum request body size accepted on OTLP endpoints (/v1/logs, /v1/metrics).
# Returns 413 above this size. Default 10MB protects against misconfigured exporters
# blasting the local server. Raise to 50_000_000 if you legitimately have huge batches.
# OTLP_MAX_BODY_BYTES=10000000
