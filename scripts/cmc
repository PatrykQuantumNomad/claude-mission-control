#!/usr/bin/env bash
# SETUP-02: Mission Control CLI dispatcher.
#
# Subcommands: start | stop | restart | status | doctor | logs | sync | setup
#
# Resolution order for the install root (CMC_HOME wins; otherwise we infer):
#   1. $CMC_HOME (when explicitly set — used by tests + power users)
#   2. ~/.command-centre (production install via install.sh --install)
#   3. The repo root (dev mode: this script lives in scripts/)
#
# Resolution order for the venv python:
#   1. $ROOT/venv/bin/python      (production install layout)
#   2. $ROOT/backend/.venv/bin/python  (dev layout)
set -euo pipefail

# ---------- resolve install root ----------
if [[ -n "${CMC_HOME:-}" ]]; then
    ROOT="$CMC_HOME"
elif [[ -d "$HOME/.command-centre" && -x "$HOME/.command-centre/venv/bin/python" ]]; then
    ROOT="$HOME/.command-centre"
else
    # Dev mode — follow symlinks to locate the repo root (handles ~/.local/bin/cmc symlink)
    SCRIPT_PATH="${BASH_SOURCE[0]}"
    if [[ -L "$SCRIPT_PATH" ]]; then
        SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    fi
    ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
fi

# ---------- resolve venv python ----------
if [[ -x "$ROOT/venv/bin/python" ]]; then
    VENV_PY="$ROOT/venv/bin/python"
elif [[ -x "$ROOT/backend/.venv/bin/python" ]]; then
    VENV_PY="$ROOT/backend/.venv/bin/python"
else
    # Fall back to system python ONLY for `help` so subcommand parsing still works
    VENV_PY=""
fi

LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
LABELS=(
    "com.cmc.server"
    "com.cmc.dispatcher"
    "com.cmc.telegram-notifier"
    "com.cmc.telegram-handler"
)

require_venv() {
    if [[ -z "$VENV_PY" ]]; then
        echo "✗ no venv found at $ROOT/{venv,backend/.venv}" >&2
        exit 1
    fi
}

# ---------- subcommands ----------
cmd_start() {
    # NB: NOT exec — exec replaces the shell, breaking cmd_restart's
    # cmd_stop → cmd_start sequence (cmd_stop would never return).
    if [[ -x "$ROOT/bin/start.sh" ]]; then
        "$ROOT/bin/start.sh"
        return $?
    fi
    for L in "${LABELS[@]}"; do
        P="$LAUNCH_AGENTS/$L.plist"
        [[ -f "$P" ]] || { echo "⚠ skip $L (plist missing)"; continue; }
        # Pitfall P1: prefer bootstrap; fall back to load -w on older macOS
        launchctl bootstrap "gui/$UID" "$P" 2>/dev/null \
            || launchctl load -w "$P" \
            || echo "✗ failed to load $L"
    done
    echo "✓ start complete"
}

cmd_stop() {
    # NB: NOT exec — see cmd_start above.
    if [[ -x "$ROOT/bin/stop.sh" ]]; then
        "$ROOT/bin/stop.sh"
        return $?
    fi
    for L in "${LABELS[@]}"; do
        launchctl bootout "gui/$UID/$L" 2>/dev/null \
            || launchctl unload "$LAUNCH_AGENTS/$L.plist" 2>/dev/null \
            || echo "(skip) $L not loaded"
    done
    echo "✓ stop complete"
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    for L in "${LABELS[@]}"; do
        if launchctl print "gui/$UID/$L" >/dev/null 2>&1; then
            echo "[loaded] $L"
        else
            echo "[ off ]  $L"
        fi
    done
}

cmd_doctor() {
    require_venv
    exec "$VENV_PY" -m cmc.cli.doctor
}

cmd_logs() {
    FILES=()
    shopt -s nullglob
    for f in "$ROOT/.tmp/mission-control-queue/dispatcher-logs/"*.out \
             "$ROOT/.tmp/mission-control-queue/dispatcher-logs/"*.err \
             "$ROOT/logs/"*.out \
             "$ROOT/logs/"*.err; do
        [[ -f "$f" ]] && FILES+=("$f")
    done
    shopt -u nullglob
    if [[ ${#FILES[@]} -eq 0 ]]; then
        echo "no logs found in $ROOT/{.tmp/mission-control-queue/dispatcher-logs,logs}"
        exit 0
    fi
    exec tail -F -n 50 "${FILES[@]}"
}

cmd_sync() {
    curl -sX POST http://127.0.0.1:8765/api/sync \
        || { echo "✗ server not reachable at 127.0.0.1:8765" >&2; exit 1; }
}

cmd_setup() {
    require_venv
    local sub="${1:-}"
    case "$sub" in
        otel)     exec "$VENV_PY" -m cmc.cli.setup_otel ;;
        telegram) exec "$VENV_PY" -m cmc.cli.setup_telegram ;;
        *) echo "Usage: cmc setup {otel|telegram}" >&2; exit 2 ;;
    esac
}

cmd_help() {
    cat <<EOF
cmc <subcommand>  — Mission Control CLI

Subcommands:
  start              Bootstrap server + dispatcher + telegram daemons under launchd
  stop               Bootout all 4 daemons
  restart            stop, sleep 1, start
  status             Show loaded/unloaded state per daemon
  doctor             8-check health report (python, claude, settings.json,
                     projects, port, /api/health, launchd state, telegram)
  logs               tail -F across all daemon logs
  sync               POST /api/sync (kick the dispatcher tick manually)
  setup otel         Atomically merge 6 OTEL env keys into ~/.claude/settings.json
  setup telegram     BotFather wizard (token + chat_id + write .env)
EOF
}

SUB="${1:-help}"
shift || true
case "$SUB" in
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    restart) cmd_restart "$@" ;;
    status) cmd_status "$@" ;;
    doctor) cmd_doctor "$@" ;;
    logs) cmd_logs "$@" ;;
    sync) cmd_sync "$@" ;;
    setup) cmd_setup "$@" ;;
    help|--help|-h) cmd_help ;;
    *) echo "unknown subcommand: $SUB" >&2; exit 2 ;;
esac
